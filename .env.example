# Copie este arquivo para .env e preencha. O .env NUNCA vai pro git.

# RPC da rede usada para ancorar. Padrao: Ethereum Sepolia (testnet).
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Identificador da rede, gravado no campo proof.chain do certificado.
# ethereum-sepolia (teste) | polygon-amoy (teste) | polygon (mainnet)
CHAIN=ethereum-sepolia

# Chave privada da conta emissora. Gere com: npm run keygen
# Use uma conta DEDICADA a isto. Nunca uma carteira pessoal.
PRIVATE_KEY=
